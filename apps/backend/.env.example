# ── BuildMart Backend Environment Variables ─────────────────
# Copy to .env and fill values. In production (Render), set these
# as environment variables in the dashboard — never commit real secrets.

# ── Database (Neon / local Postgres) ────────────────────────
# Local dev with Docker Compose (port 5433):
#   DATABASE_URL=postgresql://buildmart:buildmart@localhost:5433/buildmart_dev?connection_limit=5&pool_timeout=10
#   DIRECT_URL=postgresql://buildmart:buildmart@localhost:5433/buildmart_dev
# Local dev with native Postgres (port 5432):
#   DATABASE_URL=postgresql://buildmart:buildmart@localhost:5432/buildmart_dev?connection_limit=5&pool_timeout=10
#   DIRECT_URL=postgresql://buildmart:buildmart@localhost:5432/buildmart_dev
# Production (Neon): use pooled URL for DATABASE_URL, unpooled for DIRECT_URL
DATABASE_URL=
DIRECT_URL=

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (optional in dev, required in production) ────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRIVATE_FOLDER=buildmart-vendor-docs

# ── Razorpay (optional in dev, required in production) ──────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── MSG91 OTP (optional — dev mode logs OTP to console) ─────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── WhatsApp Business API (optional) ────────────────────────
WHATSAPP_API_KEY=
WHATSAPP_SENDER_NUMBER=

# ── Monitoring (optional) ───────────────────────────────────
SENTRY_DSN=
